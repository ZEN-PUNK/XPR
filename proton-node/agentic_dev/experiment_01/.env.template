# ====================================================================
# Proton Node Experiment 01 - Environment Configuration Template
# ====================================================================
# 
# Copy this file to .env and fill in your Azure VM details
# 
# Usage:
#   cp .env.template .env
#   # Edit .env with your values
#   source .env
#

# Azure VM Configuration
VM_IP="YOUR_VM_PUBLIC_IP"              # Example: 20.81.200.166
VM_USER="YOUR_VM_USERNAME"             # Example: azureuser (default for Azure)
VM_NAME="YOUR_VM_NAME"                 # Example: proton-node
RESOURCE_GROUP="YOUR_RESOURCE_GROUP"   # Example: PROTON-NODE

# SSH Configuration
SSH_KEY_PATH="YOUR_SSH_KEY_PATH"       # Example: ~/.ssh/proton-key.pem
# Remember to set correct permissions: chmod 400 ${SSH_KEY_PATH}

# Proton Node Configuration
RPC_PORT="8888"                        # Default RPC port
P2P_PORT="9876"                        # Default P2P port
PROTON_VERSION="v2.0.5"                # Proton version (from Docker)

# Blockchain Indexer Configuration (Optional)
# Only needed if you're using the blockchain_indexer component
RPC_URL="http://${VM_IP}:${RPC_PORT}"  # Will be constructed from above
DATABASE_TYPE="sqlite"                  # sqlite or postgres
DATABASE_PATH="data/blockchain.db"      # For SQLite
# For PostgreSQL:
# DATABASE_TYPE="postgres"
# DATABASE_HOST="localhost"
# DATABASE_PORT="5432"
# DATABASE_NAME="proton_blockchain"
# DATABASE_USER="postgres"
# DATABASE_PASSWORD="your_password"

# Azure Subscription (Optional - for Azure CLI operations)
# AZURE_SUBSCRIPTION_ID="your-subscription-id"

# ====================================================================
# Notes:
# ====================================================================
# 
# 1. VM Requirements:
#    - Ubuntu 22.04 or 18.04
#    - Minimum 2GB RAM (4GB+ recommended)
#    - 20GB+ disk space
#    - Ports 8888 and 9876 open in NSG/firewall
#
# 2. SSH Key:
#    - Generate with: ssh-keygen -t rsa -b 4096 -f ~/.ssh/proton-key
#    - Or download from Azure Portal
#    - Set permissions: chmod 400 ~/.ssh/proton-key.pem
#
# 3. Quick Test:
#    - SSH: ssh -i ${SSH_KEY_PATH} ${VM_USER}@${VM_IP}
#    - RPC: curl http://${VM_IP}:${RPC_PORT}/v1/chain/get_info
#
