# Environment Configuration - Multi-Node Consensus Network
# Copy this file to .env and fill in your values
# DO NOT commit .env file to git (contains sensitive data)

#######################################
# Azure Configuration
#######################################
AZURE_SUBSCRIPTION_ID=""  # Your Azure subscription ID
RESOURCE_GROUP="proton-consensus-network"  # Resource group name
LOCATION="eastus"  # Azure region (eastus, westus, etc.)

#######################################
# VM Configuration
#######################################
VM_SIZE="Standard_D2s_v3"  # VM size (2 vCPU, 8GB RAM)
VM_USER="azureuser"  # SSH username
VM_IMAGE="Ubuntu2204"  # Ubuntu 22.04 LTS
VM_COUNT=3  # Number of validator nodes (3, 5, 7, 21)

# Auto-populated during deployment:
VM_IP_1=""  # Public IP of VM 1 (producer-a)
VM_IP_2=""  # Public IP of VM 2 (producer-b)
VM_IP_3=""  # Public IP of VM 3 (producer-c)

#######################################
# Network Configuration
#######################################
NSG_NAME="proton-consensus-nsg"  # Network Security Group
VNET_NAME="proton-consensus-vnet"  # Virtual Network
SUBNET_NAME="proton-consensus-subnet"  # Subnet

# Ports
RPC_PORT=8888  # HTTP RPC port
P2P_PORT=9876  # P2P network port
SSH_PORT=22  # SSH access port

#######################################
# SSH Key Configuration
#######################################
SSH_KEY_PATH="${HOME}/.ssh/proton-consensus-key"  # Local path to SSH key
SSH_KEY_NAME="proton-consensus-key"  # Key name in Azure

#######################################
# Producer Configuration
#######################################
# These are auto-generated during deployment
# DO NOT manually edit unless regenerating entire network

PUBKEY_A=""  # Public key for producer-a (EOS6...)
PRIVKEY_A=""  # Private key for producer-a (5K...) 
PRODUCER_NAME_A="producer-a"

PUBKEY_B=""  # Public key for producer-b (EOS7...)
PRIVKEY_B=""  # Private key for producer-b (5K...)
PRODUCER_NAME_B="producer-b"

PUBKEY_C=""  # Public key for producer-c (EOS8...)
PRIVKEY_C=""  # Private key for producer-c (5K...)
PRODUCER_NAME_C="producer-c"

#######################################
# Blockchain Configuration
#######################################
CHAIN_ID=""  # Auto-generated from genesis.json
GENESIS_TIMESTAMP=""  # Auto-set to deployment time

# Block Production Settings
BLOCK_TIME_MS=500  # 0.5 seconds per block
BLOCKS_PER_PRODUCER=12  # 12 consecutive blocks per producer
PRODUCER_REPETITIONS=1  # Times each producer runs before rotation

#######################################
# Consensus Configuration
#######################################
CONSENSUS_THRESHOLD="2/3+1"  # BFT consensus: requires 2/3+1 validators
MIN_PRODUCERS=3  # Minimum validators for network operation
MAX_IRREVERSIBLE_BLOCK_AGE=600  # Seconds before block becomes irreversible

#######################################
# Deployment Configuration
#######################################
DEPLOYMENT_MODE="production"  # production, test, emulation
AUTO_START="true"  # Start nodes automatically after deployment
PARALLEL_DEPLOY="true"  # Deploy VMs in parallel (faster)

#######################################
# Monitoring & Logging
#######################################
LOG_LEVEL="info"  # debug, info, warn, error
ENABLE_METRICS="true"  # Enable Prometheus metrics (future)
HEALTH_CHECK_INTERVAL=60  # Seconds between health checks

#######################################
# Advanced Configuration
#######################################
DOCKER_IMAGE="ubuntu:18.04"  # Base Docker image
PROTON_VERSION="v2.0.5"  # Proton blockchain version
ENABLE_CONTRACTS_CONSOLE="true"  # Log smart contract output
MAX_CLIENTS=25  # Maximum HTTP RPC clients
